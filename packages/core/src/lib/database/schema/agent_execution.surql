DEFINE TABLE OVERWRITE agent_execution TYPE NORMAL SCHEMAFULL COMMENT "Canonical AgentExecution storage records.";
DEFINE FIELD OVERWRITE activity ON TABLE agent_execution TYPE string COMMENT "Current semantic work posture.";
DEFINE FIELD OVERWRITE agentExecutionId ON TABLE agent_execution TYPE string COMMENT "Daemon-issued AgentExecution identity inside the owner scope.";
DEFINE FIELD OVERWRITE agentId ON TABLE agent_execution TYPE string COMMENT "Selected Agent id for this AgentExecution.";
DEFINE FIELD OVERWRITE attention ON TABLE agent_execution TYPE string COMMENT "Current collaboration attention state.";
DEFINE FIELD OVERWRITE createdAt ON TABLE agent_execution TYPE string COMMENT "AgentExecution creation timestamp.";
DEFINE FIELD OVERWRITE journal ON TABLE agent_execution TYPE object COMMENT "Durable AgentExecution journal reference.";
DEFINE FIELD OVERWRITE journal.agentExecutionId ON TABLE agent_execution TYPE string COMMENT "AgentExecution identity associated with this journal.";
DEFINE FIELD OVERWRITE journal.journalId ON TABLE agent_execution TYPE string COMMENT "Durable journal identity for this AgentExecution.";
DEFINE FIELD OVERWRITE journal.lastSequence ON TABLE agent_execution TYPE int COMMENT "Last durable journal record sequence currently known.";
DEFINE FIELD OVERWRITE journal.ownerEntity ON TABLE agent_execution TYPE string COMMENT "Canonical Entity type that owns the AgentExecution journal.";
DEFINE FIELD OVERWRITE journal.ownerId ON TABLE agent_execution TYPE string COMMENT "Canonical id of the Entity that owns the AgentExecution journal.";
DEFINE FIELD OVERWRITE journal.recordCount ON TABLE agent_execution TYPE int COMMENT "Number of durable journal records currently known.";
DEFINE FIELD OVERWRITE journal.storageKey ON TABLE agent_execution TYPE option<string> COMMENT "Optional backend storage key for the durable journal.";
DEFINE FIELD OVERWRITE lifecycle ON TABLE agent_execution TYPE string COMMENT "Daemon-owned lifecycle state.";
DEFINE FIELD OVERWRITE lineage ON TABLE agent_execution TYPE option<object> COMMENT "Retry lineage when this execution was created from another AgentExecution.";
DEFINE FIELD OVERWRITE lineage.retryAttempt ON TABLE agent_execution TYPE option<int> COMMENT "Retry attempt number for this AgentExecution.";
DEFINE FIELD OVERWRITE lineage.retryOfAgentExecutionId ON TABLE agent_execution TYPE option<string> COMMENT "AgentExecution identity retried by this execution.";
DEFINE FIELD OVERWRITE mcpAvailability ON TABLE agent_execution TYPE string COMMENT "Effective MCP-backed semantic operation availability.";
DEFINE FIELD OVERWRITE messageRegistry ON TABLE agent_execution TYPE object COMMENT "Current structured AgentExecution message registry.";
DEFINE FIELD OVERWRITE messageRegistry.messages ON TABLE agent_execution TYPE array<object> COMMENT "Structured message descriptors supported by this AgentExecution.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.delivery ON TABLE agent_execution TYPE string COMMENT "Required delivery behavior for this message kind.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.description ON TABLE agent_execution TYPE option<string> COMMENT "Optional operator-facing message description.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.direction ON TABLE agent_execution TYPE string COMMENT "Direction of the AgentExecution message.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.journalEffect ON TABLE agent_execution TYPE string COMMENT "Durable journal effect produced by this message kind.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.kind ON TABLE agent_execution TYPE string COMMENT "Message kind handled by this AgentExecution.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.label ON TABLE agent_execution TYPE option<string> COMMENT "Optional operator-facing message label.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.payloadSchemaKey ON TABLE agent_execution TYPE option<string> COMMENT "Optional schema key for structured message payload validation.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.portability ON TABLE agent_execution TYPE option<string> COMMENT "Portability scope for this message kind.";
DEFINE FIELD OVERWRITE messageRegistry.messages.*.startsTurn ON TABLE agent_execution TYPE option<bool> COMMENT "Whether accepting this message starts an AgentExecution turn.";
DEFINE FIELD OVERWRITE ownerEntity ON TABLE agent_execution TYPE string COMMENT "Canonical Entity type that owns this AgentExecution.";
DEFINE FIELD OVERWRITE ownerId ON TABLE agent_execution TYPE string COMMENT "Canonical id of the owning Entity.";
DEFINE FIELD OVERWRITE transportState ON TABLE agent_execution TYPE object COMMENT "Minimal current structured transport state.";
DEFINE FIELD OVERWRITE transportState.reason ON TABLE agent_execution TYPE option<string> COMMENT "Current transport degradation or unavailability reason.";
DEFINE FIELD OVERWRITE transportState.status ON TABLE agent_execution TYPE string COMMENT "Current transport availability status.";
DEFINE FIELD OVERWRITE transportState.structuredTransport ON TABLE agent_execution TYPE string COMMENT "Structured transport currently available to this AgentExecution.";
DEFINE FIELD OVERWRITE transportState.terminalInputAvailable ON TABLE agent_execution TYPE option<bool> COMMENT "Whether terminal input is currently available as a fallback transport.";
DEFINE FIELD OVERWRITE updatedAt ON TABLE agent_execution TYPE string COMMENT "AgentExecution last update timestamp.";
DEFINE INDEX OVERWRITE agent_execution_owner_identity_idx ON TABLE agent_execution FIELDS ownerEntity, ownerId, agentExecutionId UNIQUE;
DEFINE INDEX OVERWRITE agent_execution_owner_updated_idx ON TABLE agent_execution FIELDS ownerEntity, ownerId, updatedAt;
DEFINE INDEX OVERWRITE agent_execution_lifecycle_idx ON TABLE agent_execution FIELDS lifecycle;
DEFINE INDEX OVERWRITE agent_execution_journal_idx ON TABLE agent_execution FIELDS journal.journalId UNIQUE;
