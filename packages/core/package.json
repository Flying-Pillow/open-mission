{
  "name": "@flying-pillow/mission-core",
  "version": "0.1.0-alpha.1",
  "description": "Mission core workflow orchestrator and central mission logic",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ./build/workflow/engine/copyTemplateFiles.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "MISSION_DAEMON_RUNTIME_MODE=source tsx --watch --tsconfig ./tsconfig.json ./src/daemon/missiond.ts run --dev",
    "lint": "vp lint src",
    "test": "vp test run --config vitest.config.ts"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./*": {
      "types": "./build/*.d.ts",
      "default": "./build/*.js"
    }
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@flying-pillow/zod-surreal": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@surrealdb/node": "^3.0.3",
    "@types/node": "^25.5.0",
    "surrealdb": "^2.0.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.18"
  }
}
