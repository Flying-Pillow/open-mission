{
  "name": "@flying-pillow/mission-core",
  "version": "0.1.0-alpha.0",
  "description": "Mission core workflow orchestrator and central mission logic",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ./build/workflow/engine/copyTemplateFiles.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "daemon:dev": "node ./scripts/daemon-dev.mjs",
    "lint": "vp lint src",
    "test": "vp test run --config ../../vitest.config.ts --project core"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "typescript": "./src/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./schemas": {
      "development": "./src/schemas/index.ts",
      "typescript": "./src/schemas/index.ts",
      "types": "./build/schemas/index.d.ts",
      "import": "./build/schemas/index.js",
      "default": "./build/schemas/index.js"
    },
    "./browser": {
      "development": "./src/browser.ts",
      "typescript": "./src/browser.ts",
      "types": "./build/browser.d.ts",
      "import": "./build/browser.js",
      "default": "./build/browser.js"
    },
    "./node": {
      "development": "./src/node.ts",
      "typescript": "./src/node.ts",
      "types": "./build/node.d.ts",
      "import": "./build/node.js",
      "default": "./build/node.js"
    },
    "./daemon": {
      "development": "./src/daemon.ts",
      "typescript": "./src/daemon.ts",
      "types": "./build/daemon.d.ts",
      "import": "./build/daemon.js",
      "default": "./build/daemon.js"
    }
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}