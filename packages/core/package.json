{
  "name": "@flying-pillow/mission-core",
  "version": "0.1.0-beta.0",
  "description": "Mission core workflow orchestrator and central mission logic",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ./src/workflow/templates/copyTemplateFiles.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "daemon:dev": "nodemon --watch src --ext ts --signal SIGTERM --exec \"tsx src/daemon/main.ts\"",
    "lint": "eslint src --ext .ts",
    "test": "cd ../.. && vitest run --config vitest.config.ts --project core"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./*": {
      "typescript": "./src/*",
      "default": "./build/*"
    }
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@flying-pillow/mission-airport": "workspace:*",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.10",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3"
}
