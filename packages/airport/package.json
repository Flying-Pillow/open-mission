{
  "name": "@flying-pillow/mission-airport",
  "version": "0.1.0-beta.0",
  "description": "Mission airport control-plane state and projection primitives",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    },
    "./*": {
      "typescript": "./src/*",
      "default": "./build/*"
    }
  },
  "files": [
    "build"
  ],
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3"
}
