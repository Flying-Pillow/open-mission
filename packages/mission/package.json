{
  "name": "@flying-pillow/mission",
  "version": "0.1.0-alpha.1",
  "description": "Mission CLI distribution package for the mission and missiond launchers; Mission now boots the native Airport host.",
  "type": "module",
  "bin": {
    "mission": "build/mission.js",
    "missiond": "build/missiond.js"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "install:dev": "tsx --tsconfig ./tsconfig.dev.json ./src/mission.ts install --json",
    "missiond:dev": "MISSION_DAEMON_RUNTIME_MODE=source tsx --watch --watch-path ./src --watch-path ../core/src --tsconfig ./tsconfig.dev.json ./src/missiond.ts run --dev",
    "lint": "vp lint src",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@flying-pillow/mission-airport-web": "workspace:*",
    "@flying-pillow/mission-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
