{
  "name": "@flying-pillow/open-mission",
  "version": "0.1.0-alpha.1",
  "description": "Open Mission CLI distribution package for the open-mission and open-missiond launchers.",
  "type": "module",
  "bin": {
    "open-mission": "build/open-mission.js",
    "open-missiond": "build/open-missiond.js"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "install:dev": "tsx --tsconfig ./tsconfig.dev.json ./src/open-mission.ts install --json",
    "open-mission-daemon:dev": "OPEN_MISSION_DAEMON_RUNTIME_MODE=source tsx --watch --watch-path ./src --watch-path ../core/src --tsconfig ./tsconfig.dev.json ./src/open-missiond.ts run --dev",
    "lint": "vp lint src",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@flying-pillow/open-mission-web": "workspace:*",
    "@flying-pillow/open-mission-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
