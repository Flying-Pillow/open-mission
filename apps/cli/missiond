#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

launch_mode=${MISSION_DAEMON_LAUNCH_MODE:-auto}
source_entry="$script_dir/src/daemon.ts"
build_entry="$script_dir/build/daemon.js"

if [ "$launch_mode" = "source" ] && [ -f "$source_entry" ]; then
	exec pnpm --dir "$script_dir" exec tsx "$source_entry" "$@"
fi

if [ -f "$build_entry" ]; then
	exec node "$build_entry" "$@"
fi

if [ -f "$source_entry" ]; then
	exec pnpm --dir "$script_dir" exec tsx "$source_entry" "$@"
fi

printf '%s\n' "missiond: no daemon entrypoint found. Build the CLI package first." >&2
exit 1
