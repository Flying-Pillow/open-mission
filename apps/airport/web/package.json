    "@dnd-kit/helpers": "^0.1.21",
    "@flying-pillow/mission-core": "workspace:*",
    "@tabler/icons-svelte": "^3.41.1",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.16.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "layerchart": "2.0.0-next.48",
    "marked": "^16.4.1",
    "mode-watcher": "^1.1.0",
