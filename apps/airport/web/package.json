{
  "name": "@flying-pillow/mission-airport-web",
  "version": "0.1.0-alpha.1",
  "description": "Mission Airport web host for browser-based repository and mission workflows.",
  "type": "module",
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "MISSION_SURFACE_PATH=${MISSION_SURFACE_PATH:-$(cd ../../.. && pwd)} MISSION_DAEMON_RUNTIME_MODE=${MISSION_DAEMON_RUNTIME_MODE:-source} vp dev --host 0.0.0.0 --port 5174",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "vp lint src && eslint \"src/**/*.svelte\"",
    "test": "vp test run --passWithNoTests"
  },
  "devDependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@internationalized/date": "^3.12.1",
    "@sveltejs/adapter-node": "^5.3.2",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/ws": "^8.18.1",
    "clsx": "^2.1.1",
    "mdsvex": "^0.12.6",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.18",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@flying-pillow/mission-core": "workspace:*",
    "@iconify/svelte": "^5.2.1",
    "@tanstack/svelte-virtual": "^3.13.24",
    "anser": "^2.3.5",
    "bits-ui": "^2.16.3",
    "ghostty-web": "^0.4.0",
    "github-markdown-css": "^5.9.0",
    "marked": "^16.4.1",
    "mermaid": "^11.12.2",
    "mode-watcher": "^1.1.0",
    "node-pty": "^1.1.0",
    "paneforge": "^1.0.2",
    "sanitize-html": "^2.17.0",
    "shiki": "^4.0.2",
    "svelte-sonner": "^1.1.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
