#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || {
	CDPATH= cd -- "$script_dir/../.."
	pwd
})
preload_file="$script_dir/node_modules/@opentui/solid/scripts/preload.ts"
daemon_command="$script_dir/missiond"
typescript_conditions="--conditions=typescript"
zellij_binary=${MISSION_ZELLIJ_BINARY:-zellij}
zellij_mode=${MISSION_ZELLIJ_MODE:-auto}

shell_quote() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\''/g")"
}

build_command_string() {
	command_string=
	for command_arg in "$@"; do
		quoted_arg=$(shell_quote "$command_arg")
		if [ -n "$command_string" ]; then
			command_string="$command_string $quoted_arg"
		else
			command_string=$quoted_arg
		fi
	done
	printf '%s' "$command_string"
}

resolve_zellij_session_name() {
	printf '%s' "${MISSION_TERMINAL_SESSION_NAME:-mission-$(basename "$repo_root")}"
}

resolve_runtime_root() {
	runtime_root=${XDG_RUNTIME_DIR:-}
	if [ -z "$runtime_root" ]; then
		runtime_root=${TMPDIR:-/tmp}
	fi
	printf '%s' "$runtime_root"
}

resolve_runtime_config_root() {
	session_name=$(resolve_zellij_session_name)
	session_slug=$(printf '%s' "$session_name" | tr -c '[:alnum:]._-' '_')
	printf '%s/mission/runtime-%s' "$(resolve_runtime_root)" "$session_slug"
}

ensure_zellij_runtime_config() {
	runtime_config_root=$1
	zellij_config_dir="$runtime_config_root/zellij"
	mkdir -p "$zellij_config_dir"
	cat > "$zellij_config_dir/config.kdl" <<EOF
themes {
    flightdeck {
        bg "#0F1419" // Terminal background
        
        // --- YOUR BORDER COLORS ---
        fg "#555555"    // UNSELECTED PANES: Muted Grey
        green "#1E40AF" // SELECTED PANE: Dark Blue
        
        // (These are just fallback colors for text inside Zellij UI)
        black "#000000"
        red "#FF3333"
        yellow "#E5C07B"
        blue "#61AFEF"
        magenta "#C678DD"
        cyan "#56B6C2"
        white "#FFFFFF"
        orange "#D19A66"
    }
}

// Tell Zellij to use the theme
theme "flightdeck"

// Disable startup tips so no welcome/help text is injected.
show_startup_tips false

// Keep the nice rounded corners
ui {
    pane_frames {
        rounded_corners true
    }
}
EOF
}

resolve_pilot_target_file() {
	session_name=$(resolve_zellij_session_name)
	session_slug=$(printf '%s' "$session_name" | tr -c '[:alnum:]._-' '_')
	printf '%s/mission/operator-pane-%s.target' "$(resolve_runtime_root)" "$session_slug"
}

resolve_pilot_log_file() {
	session_name=$(resolve_zellij_session_name)
	session_slug=$(printf '%s' "$session_name" | tr -c '[:alnum:]._-' '_')
	printf '%s/mission/operator-pane-%s.log' "$(resolve_runtime_root)" "$session_slug"
}

kdl_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

resolve_editor_target() {
	for candidate in \
		"$repo_root/mission.json" \
		"$repo_root/README.md" \
		"$repo_root/BRANCH_HANDOFF.md" \
		"$repo_root/CHANGELOG.md"
	do
		if [ -f "$candidate" ]; then
			printf '%s' "$candidate"
			return
		fi
	done
	printf '%s' ''
}

resolve_editor_command() {
	if [ -n "${MISSION_ZELLIJ_EDITOR_COMMAND:-}" ]; then
		printf '%s' "$MISSION_ZELLIJ_EDITOR_COMMAND"
		return
	fi
	if [ -n "${MISSION_EDITOR_COMMAND:-}" ]; then
		printf '%s' "$MISSION_EDITOR_COMMAND"
		return
	fi
	editor_target=$(resolve_editor_target)
	if [ -n "$editor_target" ]; then
		printf '%s' "$(build_command_string micro "$editor_target")"
		return
	fi
	printf '%s' "$(build_command_string micro)"
}

resolve_zellij_layout_file() {
	session_name=$(resolve_zellij_session_name)
	session_slug=$(printf '%s' "$session_name" | tr -c '[:alnum:]._-' '_')
	printf '%s/mission/flightdeck-%s.kdl' "$(resolve_runtime_root)" "$session_slug"
}

build_zellij_cockpit_command() {
	session_name=$1
	pilot_target_file=$2
	shift 2
	if [ "$hmr_mode" -eq 1 ]; then
		build_command_string env MISSION_ZELLIJ_ACTIVE=1 MISSION_TERMINAL_SESSION_NAME="$session_name" MISSION_PILOT_TARGET_FILE="$pilot_target_file" MISSION_COCKPIT_SCRIPT_DIR="$script_dir" "$script_dir/mission" --hmr "$@"
		return
	fi
	build_command_string env MISSION_ZELLIJ_ACTIVE=1 MISSION_TERMINAL_SESSION_NAME="$session_name" MISSION_PILOT_TARGET_FILE="$pilot_target_file" MISSION_COCKPIT_SCRIPT_DIR="$script_dir" "$script_dir/mission" "$@"
}

build_zellij_pilot_command() {
	session_name=$1
	pilot_target_file=$2
	pilot_log_file=$3
	build_command_string env MISSION_TERMINAL_SESSION_NAME="$session_name" MISSION_PILOT_TARGET_FILE="$pilot_target_file" MISSION_PILOT_LOG_FILE="$pilot_log_file" "$script_dir/mission-sidepane"
}

write_zellij_layout_file() {
	layout_file=$1
	cockpit_command=$2
	pilot_command=$3
	editor_command=$4
	right_width=$5
	editor_height=$6
	mkdir -p "$(dirname "$layout_file")"
	cat > "$layout_file" <<EOF
layout {
	// Override the implicit default tab template with a bare template so
	// zellij does not inject tab/status bar plugins.
	default_tab_template {
		children
	}
	tab name="FLIGHT-DECK" {
		pane split_direction="vertical" {
			pane name="MISSION" focus=true command="sh" cwd="$(kdl_escape "$repo_root")" {
				args "-lc" "$(kdl_escape "exec $cockpit_command")"
			}
			pane size="$(kdl_escape "$right_width")" split_direction="horizontal" {
				pane name="PILOT" command="sh" cwd="$(kdl_escape "$repo_root")" {
					args "-lc" "$(kdl_escape "exec $pilot_command")"
				}
				pane size="$(kdl_escape "$editor_height")" name="EDITOR" command="sh" cwd="$(kdl_escape "$repo_root")" {
					args "-lc" "$(kdl_escape "exec $editor_command")"
				}
			}
		}
	}
}
EOF
}

reset_zellij_session() {
	session_name=$1
	"$zellij_binary" delete-session --force "$session_name" >/dev/null 2>&1 || true
}

launch_zellij_session() {
	session_name=$(resolve_zellij_session_name)
	right_width=${MISSION_ZELLIJ_RIGHT_COLUMN_WIDTH:-${MISSION_ZELLIJ_OPERATOR_PANE_SIZE:-30%}}
	editor_height=${MISSION_ZELLIJ_EDITOR_HEIGHT:-35%}
	runtime_config_root=$(resolve_runtime_config_root)
	ensure_zellij_runtime_config "$runtime_config_root"
	zellij_config_dir="$runtime_config_root/zellij"
	editor_command=$(resolve_editor_command)
	pilot_target_file=$(resolve_pilot_target_file)
	pilot_log_file=$(resolve_pilot_log_file)
	pilot_command=$(build_zellij_pilot_command "$session_name" "$pilot_target_file" "$pilot_log_file")
	layout_file=$(resolve_zellij_layout_file)
	mkdir -p "$(dirname "$pilot_target_file")"
	if [ ! -f "$pilot_target_file" ]; then
		printf 'idle\n' > "$pilot_target_file"
	fi
	reset_zellij_session "$session_name"
	cockpit_command=$(build_zellij_cockpit_command "$session_name" "$pilot_target_file" "$@")
	write_zellij_layout_file "$layout_file" "$cockpit_command" "$pilot_command" "$editor_command" "$right_width" "$editor_height"
	if "$zellij_binary" --config-dir "$zellij_config_dir" --session "$session_name" --new-session-with-layout "$layout_file"; then
		return 0
	fi
	if attach_or_resurrect_zellij_session "$session_name" "$zellij_config_dir"; then
		return 0
	fi
	exit 1
}

should_launch_zellij() {
	if [ "$cockpit_mode" -ne 1 ]; then
		return 1
	fi
	if [ "${MISSION_ZELLIJ_ACTIVE:-0}" = "1" ] || [ -n "${ZELLIJ:-}" ]; then
		return 1
	fi
	if [ ! -t 0 ] || [ ! -t 1 ]; then
		if [ "$zellij_mode" = "force" ]; then
			printf '%s\n' 'mission: zellij mode requires an interactive terminal.' >&2
			exit 1
		fi
		return 1
	fi
	if command -v "$zellij_binary" >/dev/null 2>&1; then
		return 0
	fi
	if [ "$zellij_mode" = "force" ]; then
		printf '%s\n' "mission: zellij was requested but '$zellij_binary' was not found in PATH." >&2
		exit 1
	fi
	return 1
}

hmr_mode=0
while [ "$#" -gt 0 ]; do
	case "$1" in
		--hmr)
			hmr_mode=1
			shift
			;;
		--no-zellij)
			zellij_mode=off
			shift
			;;
		*)
			break
			;;
	esac
done

runner="tsx"
first_arg=${1:-}
cockpit_mode=0
artifact_mode=0
if [ -z "$first_arg" ]; then
	cockpit_mode=1
elif [ "${first_arg#--}" != "$first_arg" ]; then
	cockpit_mode=1
elif [ "$first_arg" = "artifact" ]; then
	artifact_mode=1
fi

if [ "$first_arg" = "--help" ] || [ "$first_arg" = "-h" ]; then
	zellij_mode=off
fi

if [ "$zellij_mode" != "off" ] && should_launch_zellij; then
	launch_zellij_session "$@"
fi

if [ "$hmr_mode" -eq 1 ] && [ "$cockpit_mode" -eq 1 ]; then
	exec env MISSION_COCKPIT_HMR=1 MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --watch --preload "$preload_file" "$script_dir/src/index.ts" "$@"
elif [ "$hmr_mode" -eq 1 ]; then
	runner="tsx watch"
elif [ "$cockpit_mode" -eq 1 ]; then
	exec env MISSION_DAEMON_COMMAND="$daemon_command" MISSION_DAEMON_LAUNCH_MODE=source pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$script_dir/src/index.ts" "$@"
elif [ "$artifact_mode" -eq 1 ]; then
	exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$script_dir/src/index.ts" "$@"
fi

exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$script_dir" exec $runner src/index.ts "$@"
