{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../packages/tsconfig/node.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "build",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/solid",
		"types": ["node"],
		"tsBuildInfoFile": "tsconfig.tsbuildinfo"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}