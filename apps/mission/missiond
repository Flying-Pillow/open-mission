#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

launch_mode=${MISSION_DAEMON_LAUNCH_MODE:-auto}
source_entry="$script_dir/src/daemon.ts"
build_entry="$script_dir/build/daemon.js"
node_options=${NODE_OPTIONS:-}
typescript_node_option="--conditions=typescript"

if [ -n "$node_options" ]; then
	node_options="$node_options $typescript_node_option"
else
	node_options="$typescript_node_option"
fi

if [ "$launch_mode" = "source" ] && [ -f "$source_entry" ]; then
	exec env NODE_OPTIONS="$node_options" pnpm --dir "$script_dir" exec tsx "$source_entry" "$@"
fi

if [ -f "$build_entry" ]; then
	exec node "$build_entry" "$@"
fi

if [ -f "$source_entry" ]; then
	exec env NODE_OPTIONS="$node_options" pnpm --dir "$script_dir" exec tsx "$source_entry" "$@"
fi

printf '%s\n' "missiond: no daemon entrypoint found. Build the Mission package first." >&2
exit 1
