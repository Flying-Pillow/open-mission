{
  "name": "mission",
  "version": "0.1.0-beta.0",
  "private": true,
  "publisher": "mission",
  "license": "ISC",
  "displayName": "Mission",
  "description": "VS Code Mission cockpit with provider-neutral agent runtimes and explicit repository operators.",
  "icon": "media/mission-icon.png",
  "type": "module",
  "files": [
    "out/**",
    "media/**",
    "README.md",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mission",
          "title": "Mission",
          "icon": "media/mission-icon.svg"
        }
      ]
    },
    "views": {
      "mission": [
        {
          "type": "webview",
          "id": "mission.cockpit",
          "name": "Flight Controller Cockpit"
        },
        {
          "id": "mission.overview",
          "name": "Mission Explorer",
          "icon": "media/mission-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "mission.showStatus",
        "title": "Show Mission Status",
        "category": "Mission"
      },
      {
        "command": "mission.openSettings",
        "title": "Open Mission Settings",
        "category": "Mission",
        "icon": "$(settings-gear)"
      },
      {
        "command": "mission.intakeGitHubIssue",
        "title": "Intake GitHub Issue",
        "category": "Mission"
      },
      {
        "command": "mission.openMissionFolder",
        "title": "Open Mission Folder",
        "category": "Mission"
      },
      {
        "command": "mission.openMissionArtifact",
        "title": "Open Mission Doc",
        "category": "Mission",
        "icon": {
          "light": "media/artifact-preview.svg",
          "dark": "media/artifact-preview.svg"
        }
      },
      {
        "command": "mission.editMissionArtifact",
        "title": "Edit Mission Doc",
        "category": "Mission",
        "icon": {
          "light": "media/artifact-edit-light.svg",
          "dark": "media/artifact-edit-dark.svg"
        }
      },
      {
        "command": "mission.openMissionChat",
        "title": "Launch Mission Agent",
        "category": "Mission"
      },
      {
        "command": "mission.prepareMissionArtifact",
        "title": "Run Mission Artifact Flight",
        "category": "Mission"
      },
      {
        "command": "mission.executeMissionSlice",
        "title": "Execute Mission Flight",
        "category": "Mission"
      },
      {
        "command": "mission.setMissionArtifactDisposition",
        "title": "Set Mission Artifact Disposition",
        "category": "Mission"
      },
      {
        "command": "mission.createIntermediateCommit",
        "title": "Create Intermediate Commit",
        "category": "Mission"
      },
      {
        "command": "mission.openMissionTimeline",
        "title": "Open Mission Roadmap",
        "category": "Mission"
      },
      {
        "command": "mission.previewGateIntent",
        "title": "Preview Mission Gate Intent",
        "category": "Mission"
      },
      {
        "command": "mission.refreshStatus",
        "title": "Refresh Mission Status",
        "category": "Mission"
      },
      {
        "command": "mission.checkImplementationGate",
        "title": "Check Mission Implementation Gate",
        "category": "Mission"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "mission.editMissionArtifact",
          "when": "view == mission.overview && viewItem == missionDoc",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "mission.refreshStatus",
          "when": "view == mission.cockpit",
          "group": "navigation@1"
        },
        {
          "command": "mission.openSettings",
          "when": "view == mission.cockpit",
          "group": "navigation@2"
        },
        {
          "command": "mission.openMissionChat",
          "when": "view == mission.overview",
          "group": "mission@1"
        },
        {
          "command": "mission.refreshStatus",
          "when": "view == mission.overview",
          "group": "mission@2"
        },
        {
          "command": "mission.showStatus",
          "when": "view == mission.overview",
          "group": "mission@3"
        },
        {
          "command": "mission.openSettings",
          "when": "view == mission.overview",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Mission",
      "properties": {
        "mission.rootFolder": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional explicit operational root override for Mission. Leave empty to derive the repo root automatically from the workspace and the .missions directory. Supports `${workspaceFolder}` and `${PWD}` tokens."
        },
        "mission.missionFolder": {
          "type": "string",
          "default": ".missions/active",
          "markdownDescription": "Optional override for the mission directory. By default Mission uses .missions/active under the derived repo root. Supports `${workspaceFolder}` and `${PWD}` tokens."
        },
        "mission.skillsFolder": {
          "type": "string",
          "default": ".agents/skills",
          "markdownDescription": "Optional override for the skills directory. Mission first consults .missions/settings.json and otherwise falls back to .agents/skills. Supports `${workspaceFolder}` and `${PWD}` tokens."
        }
      }
    }
  },
  "dependencies": {
    "@flying-pillow/mission-core": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @flying-pillow/mission-core build && pnpm --filter @flying-pillow/mission-adapters build && pnpm run build:webview && tsc -p tsconfig.json",
    "build:webview": "vite build",
    "check": "pnpm --filter @flying-pillow/mission-core build && pnpm --filter @flying-pillow/mission-adapters build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src vite.config.ts --ext .ts,.svelte",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "test": "pnpm --dir ../.. exec vitest run --config vitest.config.ts --project vscode-extension",
    "dev:host": "code --extensionDevelopmentPath=$PWD",
    "watch": "tsc -watch -p tsconfig.json",
    "vscode:prepublish": "pnpm run build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.10.0",
    "@vscode/vsce": "^3.7.1",
    "@xyflow/svelte": "^1.5.2",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
