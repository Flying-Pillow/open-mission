#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root="$script_dir"
app_dir="$repo_root/apps/tower/terminal"
preload_file="$app_dir/node_modules/@opentui/solid/scripts/preload.ts"
daemon_command="$repo_root/missiond"
typescript_conditions="--conditions=typescript"
zellij_binary=${MISSION_TERMINAL_BINARY:-zellij}
zellij_mode=${MISSION_TERMINAL_MODE:-auto}

shell_quote() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\''/g")"
}

build_command_string() {
	command_string=
	for command_arg in "$@"; do
		quoted_arg=$(shell_quote "$command_arg")
		if [ -n "$command_string" ]; then
			command_string="$command_string $quoted_arg"
		else
			command_string=$quoted_arg
		fi
	done
	printf '%s' "$command_string"
}

resolve_zellij_session_name() {
	printf '%s' "${MISSION_TERMINAL_SESSION:-${MISSION_TERMINAL_SESSION_NAME:-mission-$(basename "$repo_root")}}"
}

resolve_runtime_root() {
	runtime_root=${XDG_RUNTIME_DIR:-}
	if [ -z "$runtime_root" ]; then
		runtime_root=${TMPDIR:-/tmp}
	fi
	printf '%s' "$runtime_root"
}

should_launch_zellij() {
	if [ "$tower_mode" -ne 1 ]; then
		return 1
	fi
	if [ "${MISSION_TERMINAL_ACTIVE:-0}" = "1" ] || [ -n "${ZELLIJ:-}" ]; then
		return 1
	fi
	if [ ! -t 0 ] || [ ! -t 1 ]; then
		if [ "$zellij_mode" = "force" ]; then
			printf '%s\n' 'mission: zellij mode requires an interactive terminal.' >&2
			exit 1
		fi
		return 1
	fi
	if command -v "$zellij_binary" >/dev/null 2>&1; then
		return 0
	fi
	if [ "$zellij_mode" = "force" ]; then
		printf '%s\n' "mission: zellij was requested but '$zellij_binary' was not found in PATH." >&2
		exit 1
	fi
	return 1
}

hmr_mode=0
while [ "$#" -gt 0 ]; do
	case "$1" in
		--hmr)
			hmr_mode=1
			shift
			;;
		--no-zellij)
			zellij_mode=off
			shift
			;;
		*)
			break
			;;
	esac
done

runner="tsx"
first_arg=${1:-}
tower_mode=0
artifact_mode=0
if [ -z "$first_arg" ]; then
	tower_mode=1
elif [ "${first_arg#--}" != "$first_arg" ]; then
	tower_mode=1
elif [ "$first_arg" = "artifact" ]; then
	artifact_mode=1
fi

if [ "$first_arg" = "--help" ] || [ "$first_arg" = "-h" ]; then
	zellij_mode=off
fi

if [ "$zellij_mode" != "off" ] && should_launch_zellij; then
	if [ "$hmr_mode" -eq 1 ]; then
		exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$app_dir/src/index.ts" __zellij-launch__ --hmr "$@"
	fi
	exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$app_dir/src/index.ts" __zellij-launch__ "$@"
fi

if [ "$hmr_mode" -eq 1 ] && [ "$tower_mode" -eq 1 ]; then
	exec env MISSION_GATE_ID=dashboard MISSION_TOWER_HMR=1 MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --watch --preload "$preload_file" "$app_dir/src/index.ts" "$@"
elif [ "$hmr_mode" -eq 1 ]; then
	runner="tsx watch"
elif [ "$tower_mode" -eq 1 ]; then
	exec env MISSION_GATE_ID=dashboard MISSION_DAEMON_COMMAND="$daemon_command" MISSION_DAEMON_LAUNCH_MODE=source pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$app_dir/src/index.ts" "$@"
elif [ "$artifact_mode" -eq 1 ]; then
	exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$repo_root" exec bun "$typescript_conditions" --preload "$preload_file" "$app_dir/src/index.ts" "$@"
fi

exec env MISSION_DAEMON_COMMAND="$daemon_command" pnpm --dir "$app_dir" exec $runner src/index.ts "$@"