{
  "name": "@flying-pillow/mission-workspace",
  "version": "0.1.0-alpha.0",
  "description": "Mission workspace and filesystem manager for the full monorepo.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 turbo run build --filter=!@flying-pillow/mission-airport-native",
    "check": "NODE_OPTIONS=--max-old-space-size=8192 turbo run check --filter=!@flying-pillow/mission-airport-native",
    "ci:verify": "pnpm run lint && pnpm run build && pnpm run check && pnpm run test",
    "clean": "rm -rf .turbo apps/airport/web/build apps/airport/web/.svelte-kit apps/airport/native/src-tauri/target packages/*/build apps/*/*/build",
    "dev": "pnpm --filter @flying-pillow/mission run install:dev && pnpm --filter @flying-pillow/mission exec tsx --tsconfig ./tsconfig.dev.json ./src/missiond.ts stop --json && pnpm --parallel --filter @flying-pillow/mission-core --filter @flying-pillow/mission-airport-web run dev",
    "lint": "vp lint . && pnpm exec eslint \"apps/airport/web/src/**/*.svelte\"",
    "mission": "turbo run build --filter=@flying-pillow/mission-core --filter=@flying-pillow/mission && node packages/mission/build/mission.js",
    "missiond": "turbo run build --filter=@flying-pillow/mission-core --filter=@flying-pillow/mission && node packages/mission/build/missiond.js",
    "postinstall": "node ./scripts/repair-node-pty-helper-permissions.mjs",
    "release:publish": "pnpm run build && changeset publish",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^17.4.0",
    "turbo": "^2.9.6",
    "typescript-eslint": "^8.58.0",
    "vite-plus": "^0.1.18",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tauri-apps/cli",
      "esbuild",
      "node-pty"
    ]
  }
}