{
  "name": "@flying-pillow/mission-airport-terminal",
  "version": "0.1.0-alpha.0",
  "description": "Airport terminal surface package for Mission repositories and missions; the OpenTUI runtime currently requires Bun",
  "type": "module",
  "main": "build/main.js",
  "types": "build/main.d.ts",
  "exports": {
    ".": {
      "typescript": "./src/main.ts",
      "types": "./build/main.d.ts",
      "import": "./build/main.js",
      "default": "./build/main.js"
    }
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build && rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.json --emitDeclarationOnly && bun run ./scripts/build-terminal.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "layout": "bun run ./src/index.ts __airport-layout-open__",
    "dev": "AIRPORT_PANE_ID=tower bun run ./src/index.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "test:daemon-mission": "tsx src/scripts/daemonMissionSmokeTest.ts",
    "test:workflow-e2e": "tsx src/scripts/daemonCurrentWorkflowE2eTest.ts"
  },
  "dependencies": {
    "@dimforge/rapier2d-simd-compat": "^0.17.3",
    "@flying-pillow/mission-core": "workspace:*",
    "@opentui/core": "^0.1.96",
    "@opentui/solid": "^0.1.96",
    "planck": "^1.4.3",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.1.10",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3"
}
