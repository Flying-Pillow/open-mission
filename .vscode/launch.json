{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Mission Full Stack",
            "configurations": [
                "Mission Daemon"
            ],
            "stopAll": true
        }
    ],
    "configurations": [
        {
            "name": "Mission Daemon",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/packages/adapters",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/packages/adapters/src/main.ts",
            "args": [
                "--socket",
                "${workspaceFolder}/.vscode/mission-debug.sock"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}